{
  "name": "icejardins-react",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:content && npm run build:search-index && vite",
    "build:content": "node scripts/build-content.mjs",
    "build:search-index": "node scripts/build-search-index.mjs",
    "build:client": "vite build",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir dist-ssr",
    "prerender": "node scripts/prerender.mjs",
    "build": "npm run build:content && npm run build:search-index && npm run build:client && npm run build:ssr && npm run prerender",
    "preview": "vite preview",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "bootstrap": "^5.3.5",
    "bootstrap-icons": "^1.11.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.4.1",
    "gray-matter": "^4.0.3",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "toml": "^3.0.0",
    "typescript": "^5.8.3",
    "unist-util-visit": "^5.0.0",
    "vite": "^5.4.19"
  }
}
